{
  "name": "cursor-recent-projects",
  "displayName": "Recent Projects (IntelliJ-style)",
  "description": "Open recently opened projects from a list, like IntelliJ IDEA's Open Recent",
  "version": "0.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:cursor-recent-projects.openRecent"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursor-recent-projects.openRecent",
        "title": "Open Recent Project..."
      }
    ],
    "keybindings": [
      {
        "command": "cursor-recent-projects.openRecent",
        "key": "alt+r"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "sql.js": "^1.10.0"
  }
}
